{
  "name": "nodes-connector",
  "version": "0.1.2",
  "description": "Framework-agnostic core and React bindings for rendering node boards with many-to-many connectors.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://kzares-dev.github.io/nodes-connector/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kzares-dev/nodes-connector.git"
  },
  "bugs": {
    "url": "https://github.com/kzares-dev/nodes-connector/issues"
  },
  "keywords": [
    "nodes",
    "graph",
    "flowchart",
    "diagram",
    "connectors",
    "react",
    "typescript",
    "storybook"
  ],
  "files": [
    "dist",
    "docs/images"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/react/styles.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs",
      "default": "./dist/core/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs",
      "default": "./dist/react/index.js"
    },
    "./react-native": {
      "types": "./dist/react-native/index.d.ts",
      "import": "./dist/react-native/index.js",
      "require": "./dist/react-native/index.cjs",
      "default": "./dist/react-native/index.js"
    },
    "./react/styles.css": "./dist/react/styles.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "screenshots:docs": "node scripts/capture-docs-screenshots.mjs",
    "pack:check": "npm pack --dry-run",
    "test": "npm run typecheck && npm run build"
  },
  "peerDependencies": {
    "react": ">=18.2.0 || >=19.0.0",
    "react-dom": ">=18.2.0 || >=19.0.0",
    "react-native": ">=0.73.0",
    "react-native-svg": ">=15.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@emnapi/runtime": "^1.11.0",
    "@storybook/addon-docs": "^10.4.3",
    "@storybook/react-vite": "^10.4.3",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "playwright": "^1.60.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.4.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2"
  }
}
